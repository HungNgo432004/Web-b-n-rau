include ../mixins/sub-menu.pug
header.header
  .header__top
    .container
      .row
        .col-lg-6.col-md-6
          .header__top__left
            ul
              li
                i(class="fa fa-envelope") ngothehung44999@gmail.com
              li Miễn phí ship cho đơn hàng từ 200.000đ
        .col-lg-6.col-md-6
          .header__top__right
            .header__top__right__auth
              if(user)
                li 
                  a(href="/user/info") #{user.fullName}
                li 
                  a(href="/user/logout") Đăng xuất
              else 
                li 
                  a(href="/user/login") Đăng nhập
                li 
                  a(href="/user/register") Đăng ký
  .container
    .row
      .col-lg-3
        .header__logo
          a(href="./index.html")
            img(src="/images/logo.png", alt="Logo")
      .col-lg-6
        nav.header__menu
          ul
            li
              a(href="/") Trang chủ
            li(class="sub-menu") 
                - const pathProduct = "/products"
                a(href=pathProduct) Sản phẩm
                if(layoutProductsCategory) 
                    +sub-menu(layoutProductsCategory, pathProduct)
            li
              a(href="/cart") Giỏ hàng (#{miniCart ? miniCart.totalQuantity : 0})
            li
              a(href="./checkout") Thanh toán
