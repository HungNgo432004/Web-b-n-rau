extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .product-detail
    .container.my-5
      .row
        .col-md-6
          .inner-thumb.border.rounded.shadow-sm.p-3.bg-white
            img.img-fluid.rounded(src=product.thumbnail, alt=product.title)

        .col-md-6
          .inner-info.bg-light.p-4.rounded.shadow-sm
            h1.inner-title.mb-3.text-primary #{product.title}

            if (product.category)
              .inner-category.mb-2
                strong.text-secondary Danh mục: 
                a(href=`/products/${product.category.slug}`, class="ms-1 text-decoration-none text-dark fw-semibold") #{product.category.title}

            if (product.priceNew)
              .inner-price-new.text-danger.h4.mb-2 #{product.priceNew}$

            if (product.price)
              .inner-price-old.text-muted.text-decoration-line-through.mb-2 #{product.price}$

            if (product.discountPercentage)
              .inner-percent.text-success.mb-2
                | Giảm tới 
                span.fw-bold.ms-1 #{product.discountPercentage}$

            if (product.stock)
              .inner-stock.mb-3
                | Còn lại 
                span.fw-bold.text-warning.ms-1 #{product.stock}
                |  sản phẩm

            form(action=`/cart/add/${product.id}`, method="POST", class="mt-3")
              .mb-3
                label.form-label(for="quantity") Số lượng:
                input.form-control(type="number", name="quantity", value="1", min="1", max=product.stock)

              button.btn.btn-success.btn-lg.btn-block.w-100(type="submit")
                i.fas.fa-cart-plus.me-2
                | Thêm vào giỏ hàng

    hr

    .container.my-5
      .row
        .col-12
          +box-head("Mô tả sản phẩm")
          .inner-desc.bg-white.p-4.rounded.shadow-sm
            != product.description
