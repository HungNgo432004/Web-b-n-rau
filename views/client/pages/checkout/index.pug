extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
    +alert-success(5000)
    +alert-error(5000)

    .container.my-5 
        .row 
            .col-12 
                +box-head("Đặt hàng")

        .row 
            .col-12 
                table.table.table-bordered.table-striped.table-hover
                    thead.bg-dark.text-white 
                        tr
                            th STT
                            th Ảnh 
                            th Tên 
                            th Giá
                            th Số lượng
                            th Tổng tiền
                    tbody
                        if(cartDetail.products.length > 0)
                            each item, index in cartDetail.products
                                tr
                                    td #{index + 1}
                                    td 
                                        img(src=item.productInfo.thumbnail, alt=item.productInfo.title, width="80px", class="img-fluid rounded")
                                    td #{item.productInfo.title}
                                    td #{item.productInfo.priceNew}$ 
                                    td #{item.quantity}
                                    td #{item.totalPrice}$
                        else 
                            tr 
                                td(colspan="6", class="text-center") Giỏ hàng trống 
                if(cartDetail.products.length > 0)
                    .row
                        .col-12.text-right
                            h3 Tổng đơn hàng: <span class="text-success">#{cartDetail.totalPrice}$</span>

        if(cartDetail.products.length > 0)
            .row 
                .col-12 
                    .card.p-4.my-4.shadow-lg 
                        form(action=`/checkout/order`, method="POST")
                            .form-group 
                                label(for="fullName") Họ tên
                                input(type="text", class="form-control", id="fullName", name="fullName", required)
                            .form-group 
                                label(for="phone") Số điện thoại
                                input(type="phone", class="form-control", id="phone", name="phone", required)
                            .form-group 
                                label(for="address") Địa chỉ
                                input(type="text", class="form-control", id="address", name="address", required)
                            .form-group 
                                label(for="paymentMethod") Phương thức thanh toán
                                select(class="form-control", id="paymentMethod", name="paymentMethod", required)
                                    option(value="" disabled selected) -- Chọn phương thức --
                                    option(value="cod") Thanh toán khi nhận hàng (COD)
                                    option(value="bank") Chuyển khoản ngân hàng

                            //- THÔNG TIN CHUYỂN KHOẢN (ẩn mặc định)
                            .form-group#bankInfo(style="display: none;")
                                label Thông tin chuyển khoản:
                                p Số tài khoản: <strong>0967202939 - Ngân hàng MB - Chủ tài khoản: Ngô Thế Hưng</strong>
                                img(src="/images/image.png", alt="QR chuyển khoản", width="200")
                            .form-group
                                button(type="submit", class="btn btn-success btn-block") ĐẶT HÀNG
    //- JavaScript để hiển thị thông tin chuyển khoản khi chọn đúng phương thức
    script.
        document.addEventListener('DOMContentLoaded', function () {
            const paymentSelect = document.getElementById('paymentMethod');
            const bankInfo = document.getElementById('bankInfo');
            paymentSelect.addEventListener('change', function () {
                if (this.value === 'bank') {
                    bankInfo.style.display = 'block';
                } else {
                    bankInfo.style.display = 'none';
                }
            });
        });
