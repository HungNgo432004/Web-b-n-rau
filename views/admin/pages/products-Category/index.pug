extends ../../layouts/default.pug 
include ../../mixins/table-tree.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
include ../../mixins/sort copy.pug
include ../../mixins/moment.pug
block main 
    if(role.permissions.includes("products-categoy_view"))
        +alert-success(5000)
        h1(class="mb-4") Danh mục sản phẩm
        .card.mb-3 
            .card-header Bộ lọc và tìm kiếm 
            .card-body 
                .row 
                    .col-6 
                        +filter-status(filterStatus)
                    .col-6
                        +search(keyword)
        .card.mb-3 
            .card-header Sắp xếp
            .card-body 
                .row 
                    .col-4 
                        +sort()
        .card.mb-3 
            .card-header Danh sách 
            .card-body 
                .row 
                    .col-10
                        if(role.permissions.includes("products_edit"))
                            +form-change-multi(`${prefixAdmin}/products-category/change-multi?_method=PATCH`)
                    .col-2
                        if(role.permissions.includes("products_create"))
                            a(
                                href=`${prefixAdmin}/products-category/create`
                                class="btn btn-outline-success"
                            ) + Thêm mới
                table(
                    class="table table-hover table-sm"
                    checkbox-multi
                )
                    thead 
                        tr 
                            th 
                                input(type="checkbox" name="checkall")
                            th STT
                            th Hình ảnh 
                            th Tiêu đề
                            th Vị trí
                            th Trạng thái
                            th Người tạo  
                            th Người cập nhật   
                            th Hành động
                    tbody 
                        +table-tree(productCategory, pagination)
        form(
            id="form-change-status"
            method="POST"
            action=""
            data-path=`${prefixAdmin}/products-category/change-status`
        )
        
        form(
            id="form-delete-item"
            method="POST"
            action=""
            data-path=`${prefixAdmin}/products-category/delete`
        )
        +pagination(pagination)
