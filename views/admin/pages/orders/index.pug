extends ../../layouts/default.pug 
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug
include ../../mixins/sort copy 2.pug
include ../../mixins/moment.pug
block main 
    h1(class="mb-4") Danh sách đơn hàng
    +alert-success(5000)
    .card.mb-3 
        .card-header Bộ lọc và tìm kiếm 
        .card-body 
            .row 
                .col-6 
                    +filter-status(filterStatus)
                .col-6
                    +search(keyword)
    .card.mb-3 
        .card-header Sắp xếp
        .card-body 
            .row 
                .col-4 
                    +sort()
    .card.mb-3 
        .card-header Danh sách 
        .card-body 
            table(class="table table-hover table-sm")
                thead 
                
                    tr 
                        th STT
                        th Họ tên
                        th Số điện thoại
                        th Địa chỉ
                        th Ngày đặt hàng
                        th Trạng thái 
                        th Hành động
                tbody 
                    if order && order.length > 0
                        each item, index in order
                            tr 
                                td #{pagination.limitItem*(pagination.currentPage - 1) + (index+1)} 
                                td #{item.userInfo.fullName}
                                td #{item.userInfo.phone}
                                td #{item.userInfo.address}
                                td 
                                    +formatDateTime(item.createdAt)
                                td      
                                    if item.status == "delivered"
                                        span(class="badge bg-success") Đã giao
                                    else if item.status == "shipping"
                                        span(class="badge bg-warning") Đang giao
                                    else if item.status == "processing"
                                        span(class="badge bg-info") Đang xử lý
                                    else
                                        span(class="badge bg-secondary") Chưa xác định
                                td 
                                    a(
                                        href=`${prefixAdmin}/orders/detail/${item.id}`
                                        class="btn btn-secondary btn-sm"
                                    ) Chi tiết
                                    if item.status == "processing"
                                        button( 
                                            class="btn btn-primary btn-sm ml-1" 
                                            button-change-status-Order
                                            data-status-Order =item.status
                                            data-id-Order =item.id
                                        ) bàn giao cho vận chuyển
                                    else if item.status == "shipping"
                                        button( 
                                            class="btn btn-success btn-sm ml-1" 
                                            button-change-status-Order
                                            data-status-Order =item.status
                                            data-id-Order =item.id
                                        ) Giao thành công
                                    button(
                                        class="btn btn-danger btn-sm ml-1"
                                        button-delete
                                        data-id=item.id
                                    ) Xóa
                        h3 Tổng số lượng sản phẩm đã đặt:
                        ul
                        each item in namedProductQuantities
                            li #{item.name}: #{item.quantity} sản phẩm

                    else 
                        tr 
                            td(
                                colspan="7"  
                                class="text-center"
                            ) Không tìm thấy đơn hàng nào
    
            form(
                id="form-delete-item"
                method="POST"
                action=""
                data-path=`${prefixAdmin}/orders/delete`
            )
            form(
            id="form-change-status-Order"
            method="POST"
            action=""
            data-path=`${prefixAdmin}/orders/change-status`
            )
            +pagination(pagination)
            
