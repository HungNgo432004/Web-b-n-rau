extends ../../layouts/default.pug 
include ../../mixins/table-tree.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi copy.pug
include ../../mixins/alert.pug
include ../../mixins/sort copy.pug
include ../../mixins/moment.pug
block main
  if(role.permissions.includes("users_view"))
      +alert-success(5000)
      h1(class="mb-4") Quản lý người dùng
      .card.mb-3 
          .card-header Bộ lọc và tìm kiếm 
          .card-body 
              .row 
                  .col-6 
                      +filter-status(filterStatus)
                  .col-6
                      +search(keyword)
      .card.mb-3 
          .card-header Sắp xếp
          .card-body 
              .row 
                  .col-4 
                      +sort()
      .card.mb-3 
          .card-header Danh sách 
          .card-body 
              .row 
                  .col-10
                          +form-change-multi(`${prefixAdmin}/user/change-multi?_method=PATCH`)
                  .col-2
                    if(role.permissions.includes("users_create"))
                          a(
                              href=`${prefixAdmin}/user/create`
                              class="btn btn-outline-success"
                          ) + Thêm mới
          table(
            class="table table-hover table-sm"
            checkbox-multi
          )
            thead
              tr
                th 
                  input(type="checkbox" name="checkall")
                th STT
                th Avatar
                th Họ tên
                th Email
                th Trạng thái
                th Hành động

            tbody
              each item, index in records
                tr 
                  td 
                    input(
                        type="checkbox" 
                        name="id" 
                        value=item.id
                    )
                  td #{paginationUser.limitItem*(paginationUser.currentPage - 1) + (index+1)}
                  td
                    img(
                      src=item.avatar
                      alt=item.fullName
                      width="100px"
                      height="auto"
                    )
                  td #{item.fullName}
                  td #{item.email}
                  td 
                      if(item.status == "active")
                          button( 
                              class="badge bg-success" 
                              button-change-status 
                              data-status=item.status
                              data-id=item.id
                          ) Hoạt động
                      else
                          button(
                              class="badge bg-danger" 
                              button-change-status 
                              data-status=item.status
                              data-id=item.id
                          ) Dừng hoạt động
                  td
                    if(role.permissions.includes("users_view"))
                      a(
                        class="btn btn-secondary btn-sm"
                        href=`${prefixAdmin}/user/detail/${item.id}`
                      ) Chi tiết
                    if(role.permissions.includes("users_edit"))
                      a(
                        class="btn btn-warning btn-sm ml-1"
                        href=`${prefixAdmin}/user/edit/${item.id}`
                      ) Sửa
                      if(role.permissions.includes("users_delete"))
                        button(
                            class="btn btn-danger btn-sm ml-1"
                            button-delete
                            data-id=item.id
                        ) Xóa
      form(
          id="form-change-status"
          method="POST"
          action=""
          data-path=`${prefixAdmin}/user/change-status`
      )     
      form(
          id="form-delete-item"
          method="POST"
          action=""
          data-path=`${prefixAdmin}/user/delete`
      )
      +pagination(paginationUser)
  else
   p Bạn không có quyền truy cập vào trang này.