.sider
  .inner-menu
    ul
      li
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-tachometer-alt") Tổng quan
      if(role.permissions.includes("products-categoy_view"))
        li
          a(href=`${prefixAdmin}/products-category`)
            i(class="fas fa-box") Danh mục sản phẩm
      if(role.permissions.includes("products_view"))
        li
          a(href=`${prefixAdmin}/products`)
            i(class="fas fa-box") Sản phẩm
      li
        a(href=`${prefixAdmin}/orders`)
          i(class="fas fa-shopping-cart") Quản lý đơn hàng
      if(role.permissions.includes("roles_view"))
        li
          a(href=`${prefixAdmin}/roles`)
            i(class="fas fa-users-cog") Nhóm quyền
        li
          a(href=`${prefixAdmin}/roles/permissions`)
            i(class="fas fa-shield-alt") Phân quyền
      if(role.permissions.includes("accounts_view"))
        li
          a(href=`${prefixAdmin}/accounts`)
            i(class="fas fa-user-circle") Tài khoản Admin
      li
        a(href=`${prefixAdmin}/user`)
          i(class="fas fa-user-circle") Tài khoản người dùng

