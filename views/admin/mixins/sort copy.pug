mixin sort()
    div(sort)
        select(
            class="form-control"
            name="sort"
            sort-select 
        )
            option(value="fullName-desc") Tiêu đề A - Z
            option(value="fullName-asc") Tiêu đề Z - A
        button(
            class="btn btn-danger mt-2"
            sort-clear 
        ) Clear 